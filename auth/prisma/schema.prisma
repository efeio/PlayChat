generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model User {
  id          String   @id @default(uuid())
  displayName String
  username    String   @unique
  email       String   @unique
  password    String?
  provider    String   @default("LOCAL")
  createdAt   DateTime @default(now())
}